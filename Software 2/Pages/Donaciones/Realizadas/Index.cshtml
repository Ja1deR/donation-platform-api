@page
@model Software_2.Pages.Donaciones.Realizadas.IndexModel
@{
    ViewData["Title"] = "Mis Donaciones";
}

<div class="container py-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1><i class="fas fa-gift me-2"></i> Mis Donaciones</h1>
        <a asp-page="/Donaciones/Publicar" class="btn btn-primary">
            <i class="fas fa-plus me-2"></i> Nueva Donación
        </a>
    </div>

    <div class="card">
        <div class="card-header bg-white">
            <h5 class="mb-0">Historial de Donaciones</h5>
        </div>
        <div class="card-body">
            <div class="table-responsive">
                <table class="table table-hover">
                    <thead>
                        <tr>
                            <th>Fecha</th>
                            <th>Productos</th>
                            <th>Cantidad</th>
                            <th>Estado</th>
                            <th>Destino</th>
                            <th>Acciones</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td>15/06/2023</td>
                            <td>Arroz, frijoles, aceite</td>
                            <td>25 kg</td>
                            <td><span class="badge bg-success-light text-success">Entregado</span></td>
                            <td>Banco de Alimentos</td>
                            <td>
                                <button class="btn btn-sm btn-outline-primary">
                                    <i class="fas fa-eye"></i>
                                </button>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>